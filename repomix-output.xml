                            type: TextInputType.emailAddress,
                          ),
                          const SizedBox(height: 16),
                          const Text('PASSWORD', style: AeroText.label),
                          const SizedBox(height: 8),
                          TextField(
                            controller: passwordController,
                            obscureText: obscurePassword,
