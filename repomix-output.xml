      ),
    );
  }

  Widget _buildHeader(BuildContext context) {
    return Container(
      color: AeroColors.navy,
      padding: const EdgeInsets.fromLTRB(20, 16, 20, 16),
      child: Row(
        children: [
          GestureDetector(
