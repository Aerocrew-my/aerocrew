rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validPublicRole(role) {
      return role == 'crew' || role == 'operator';
    }

    function validInitialProfile(userId) {
      return isOwner(userId)
        && request.resource.data.keys().hasAll([
          'name', 'email', 'phone', 'role', 'status', 'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'name', 'email', 'phone', 'role', 'status', 'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.phone is string
        && validPublicRole(request.resource.data.role)
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time;
    }

    function protectedProfileFieldsAreUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role',
        'admin',
        'isAdmin',
        'status',
        'approvalStatus',
        'verificationStatus',
        'verified'
      ]);
    }

    match /users/{userId} {
      allow create: if validInitialProfile(userId);
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && protectedProfileFieldsAreUnchanged();
      allow delete: if false;
    }

    // trips, pools, rosters, and payments remain denied until their ownership
    // models and trusted server write paths have dedicated production rules.
  }
}
